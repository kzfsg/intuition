			],
			"settings": {
				"foreground": "#a5d6ff"
			}
		},
		{
			"scope": "support",
			"settings": {
				"foreground": "#79c0ff"
			}
		},
		{
			"scope": "meta.property-name",
			"settings": {
				"foreground": "#79c0ff"
			}
		},
		{
			"scope": "variable",
			"settings": {
				"foreground": "#ffa657"
			}
		},
		{
			"scope": "variable.other",
			"settings": {
				"foreground": "#c9d1d9"
			}
		},
		{
			"scope": "invalid.broken",
			"settings": {
				"foreground": "#ffa198",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "invalid.deprecated",
			"settings": {
				"foreground": "#ffa198",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "invalid.illegal",
			"settings": {
