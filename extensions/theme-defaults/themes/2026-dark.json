	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": {
				"foreground": "#8b949e"
			}
		},
		{
			"scope": [
				"constant.other.placeholder",
				"constant.character"
			],
			"settings": {
				"foreground": "#ff7b72"
			}
		},
		{
			"scope": [
				"constant",
				"entity.name.constant",
				"variable.other.constant",
				"variable.other.enummember",
				"variable.language",
